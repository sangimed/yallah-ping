{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["chrome"],
    "useDefineForClassFields": true
  },
  "include": ["src/**/*.ts"]
}
